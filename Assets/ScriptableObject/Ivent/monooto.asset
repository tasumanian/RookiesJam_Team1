  statement: "\u308F\u305F\u3057\u306F\u7B2C\u4E00\u767A\u898B\u8005\u3060\uFF01\u90E8\u5C4B\u306E\u5916\u306B\u3044\u305F\uFF01\n\u305D\u308C\u306F\u4ED6\u306E\u3058\u3085\u3046\u8005\u305F\u3061\u3082\u898B\u3066\u3044\u308B\u306F\u305A\u3060\uFF01"
