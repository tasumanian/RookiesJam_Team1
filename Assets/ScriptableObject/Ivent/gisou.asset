  m_EditorClassIdentifier: 
  statement: "\u8A00\u3044\u304C\u304B\u308A\u3060\uFF01\u52D5\u6A5F\u306A\u3089\u307B\u304B\u306E\u4E8C\u4EBA\u306B\u3082\u3042\u308B\uFF01\n\u305D\u3046\u3060\uFF01\u606F\u5B50\u306E\u90E8\u5C4B\u304B\u3089\u5B9D\u77F3\u304C\u898B\u3064\u304B\u3063\u305F\u306E\u3060\u308D\u3046\u3002\n\u3042\u3044\u3064\u304C\u3084\u3063\u305F\u306B\u9055\u3044\u306A\u3044\uFF01"
  speaker: "\u3057\u3064\u3058\u9577"
