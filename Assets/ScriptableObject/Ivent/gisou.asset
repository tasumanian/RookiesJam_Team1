  answerItem: {fileID: 11400000, guid: 448a6f5706dbea34ea1deda123dab020, type: 2}
  answerText: "\u3042\u306A\u305F\u306F\u300C\u30DE\u30B9\u30BF\u30FC\u30AD\u30FC\u300D\u3092\u6301\u3063\u3066\u3044\u307E\u3057\u305F\u306D\uFF1F\u305D\u308C\u306A\u3089\u6BBA\u5BB3\u5F8C\n\u306B\u507D\u88C5\u3059\u308B\u3053\u3068\u3082\u53EF\u80FD\u3067\u306F\u306A\u3044\u3067\u3059\u304B\u3002"
