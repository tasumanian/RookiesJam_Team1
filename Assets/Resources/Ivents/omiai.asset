  content: "\u300C\u3057\u3064\u4E8B\u9577\u306E\u5B6B\u3068\u606F\u5B50\u306E\u304A\u898B\u5408\u3044\uFF11\u300D\n\u300C\u3057\u3064\u4E8B\u9577\u304C\u5E30\u3063\u3066\u304D\u305F\u969B\u306B\u3001\u3050\u3061\u3092\u304A\u3063\u3057\u3083\u3063\u3066\u3044\u305F\u306E\u3067\u3059\u304C\u3001\u300C\u6700\u8FD1\u306E\u3060\u3093\u306A\u69D8\u306F\u308F\u305F\u3057\u306E\u5B6B\u3068\u3042\u306E\u606F\u5B50\u3092\u304A\u898B\u5408\u3044\u3055\u305B\u3066\u3053\u3088\u3046\u3068\u3059\u308B\u306E\u3060\u3002\u3002\u3002\u3044\u304B\u306B\u3060\u3093\u306A\u69D8\u3068\u306F\u3044\u3048\u3001\u3042\u307E\u308A\u306E\u3053\u3046\u3068\u3046\u3080\u3051\u3044\u3055\u306B\u3044\u304B\u308A\u3092\u899A\u3048\u3066\u3057\u307E\u3063\u305F\u3088\u300D\u3068\u304A\u3063\u3057\u3083\u3063\u3066\u3044\u307E\u3057\u305F\u300D"
